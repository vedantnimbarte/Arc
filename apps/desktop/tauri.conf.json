{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ARC",
  "version": "0.0.1",
  "identifier": "dev.arc.terminal",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "pnpm --filter @arc/frontend dev",
    "beforeBuildCommand": "pnpm --filter @arc/frontend build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ARC",
        "width": 1280,
        "height": 820,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "center": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "AI-native terminal & agent runtime",
    "longDescription": "ARC is an AI-native terminal that combines high-performance shell I/O with agent orchestration and an embedded code editor."
  }
}
